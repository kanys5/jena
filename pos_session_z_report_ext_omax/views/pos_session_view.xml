<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <record id="res_config_settings_view_form_session_z_report_omax" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.session.z.report</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"></field>
        <field name="arch" type="xml">
            <!--xpath expr="//div[@id='auto_printing']" position='inside'-->
            <xpath expr="//block[@id='pos_bills_and_receipts_section']" position='inside'>
                <setting id="show_details_in_session_z_report" help="Assign here in order to include below details to Session Z Report.">
                    <field name="show_details_in_session_z_report"/>
                    <div class="content-group mt16" invisible="show_details_in_session_z_report == False">

                        <div class="o_setting_left_pane"><field name="show_product_wise_detail"/></div>
                        <div class="o_setting_right_pane">
                            <label for="show_product_wise_detail"/>
                            <div class="content-group" invisible="show_product_wise_detail == False">
                                <div class="mt16">
                                    <field name="product_or_variant" class="o_light_label" widget="radio"/>
                                </div>
                            </div>
                        </div>
                        
                        <br/>
                        <div class="o_setting_left_pane"><field name="show_category_wise_sales"/></div>
                        <div class="o_setting_right_pane">
                            <label for="show_category_wise_sales"/>
                            <div class="text-muted"><font color="white">..</font></div>
                        </div>
                        
                        <div class="o_setting_left_pane"><field name="show_taxes_detail"/></div>
                        <div class="o_setting_right_pane">
                            <label for="show_taxes_detail"/>
                            <div class="text-muted"><font color="white">..</font></div>
                        </div>

                        <div class="o_setting_left_pane"><field name="show_pricelist_detail"/></div>
                        <div class="o_setting_right_pane">
                            <label for="show_pricelist_detail"/>
                            <div class="text-muted"><font color="white">..</font></div>
                        </div>

                        <div class="o_setting_left_pane"><field name="show_payment_detail"/></div>
                        <div class="o_setting_right_pane">
                            <label for="show_payment_detail"/>
                            <div class="text-muted"><font color="white">..</font></div>
                        </div>

                        <div class="o_setting_left_pane"><field name="show_cash_in_out_details"/></div>
                        <div class="o_setting_right_pane">
                            <label for="show_cash_in_out_details"/>
                            <div class="text-muted"><font color="white">..</font></div>
                        </div>
                    </div>
                        
                </setting>
                <setting id="omax_session_z_report" help="This will allow to print Session Z Report directly from POS screen.">
                    <field name="omax_session_z_report"/>
                </setting>

            </xpath>
        </field>
    </record>

	<record id="view_pos_session_form_report_button" model="ir.ui.view">
        <field name="name">pos.session.form.view.session.button</field>
        <field name="model">pos.session</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_session_form"></field>
        <field name="arch" type="xml">
        	<xpath expr="//header/button[@name='action_pos_session_closing_control']" position='after'>
                <button name="action_session_z_report" type="object" string="Session Z Report" class="oe_highlight"/>
            </xpath>
        </field>
    </record>
</odoo>
