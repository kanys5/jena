<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_session_z_report_ext_omax.ControlButtons" t-inherit="point_of_sale.ControlButtons" t-inherit-mode="extension">
        <xpath expr="//t[@t-if='props.showRemainingButtons']/div/button[hasclass('o_pricelist_button')]" position="before">
            <button t-if="omaxSessionZreport" t-att-class="buttonClass" t-on-click="() => this.onClickSessionReport()">
                <i class="fa fa-calculator"/> Session Report
            </button>
        </xpath>
    </t>
</templates>  

