<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_shop_booking_tree" model="ir.ui.view">
        <field name="name">shop.booking.tree</field>
        <field name="model">shop.booking</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="shop_id"/>
                <field name="visitor_name"/>
                <field name="visitor_email"/>
                <field name="meeting_datetime"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="view_shop_booking_form" model="ir.ui.view">
        <field name="name">shop.booking.form</field>
        <field name="model">shop.booking</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button
                        name="action_confirm"
                        type="object"
                        string="Confirm"
                        class="btn-primary"
                        invisible="status == 'confirmed'"
                    />
                    <button
                        name="action_cancel"
                        type="object"
                        string="Cancel"
                        invisible="status == 'cancelled'"
                    />
                    <button
                        name="action_create_quotation"
                        type="object"
                        string="Create Quotation"
                        class="btn-secondary"
                        invisible="sale_order_id or status == 'cancelled'"
                    />
                    <button
                        name="action_view_quotation"
                        type="object"
                        string="Open Quotation"
                        class="btn-secondary"
                        invisible="not sale_order_id"
                    />
                    <field name="status" widget="statusbar" statusbar_visible="requested,confirmed,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="shop_id"/>
                            <field name="meeting_datetime"/>
                            <field name="company_name"/>
                            <field name="sale_order_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="visitor_name"/>
                            <field name="visitor_email"/>
                            <field name="visitor_phone"/>
                            <field name="partner_id" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_shop_booking" model="ir.actions.act_window">
        <field name="name">Bookings</field>
        <field name="res_model">shop.booking</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_shop_booking"
        name="Bookings"
        parent="menu_building_booking_root"
        action="action_shop_booking"
        sequence="20"
    />
</odoo>
